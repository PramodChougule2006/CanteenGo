<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== SUCCESS HERO BANNER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_gradient"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="50dp"
            android:paddingBottom="36dp">

            <!-- Success Pulse Circle -->
            <LinearLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_hero_icon_circle"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="46sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="sans-serif-medium"
                android:text="Order Confirmed!"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Your food is being freshly prepared"
                android:textColor="#FFE8DC"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ===== TOKEN CONTENT SHEET ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="32dp"
            android:paddingEnd="20dp"
            android:paddingBottom="36dp">

            <!-- Token Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Token Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_veg"
                        android:letterSpacing="0.1"
                        android:paddingStart="14dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="5dp"
                        android:text="ORDER TOKEN"
                        android:textColor="@color/colorBadgeVeg"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Order ID — ID preserved: orderIdTv -->
                    <TextView
                        android:id="@+id/orderIdTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <!-- Amount — ID preserved: amountTv -->
                    <TextView
                        android:id="@+id/amountTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="22dp"
                        android:background="@color/colorDivider" />

                    <!-- QR Instruction -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="18dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Scan at the counter to collect"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- QR Image Container — ID preserved: qrImage -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        app:cardBackgroundColor="#FAFAFA"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">

                            <ImageView
                                android:id="@+id/qrImage"
                                android:layout_width="220dp"
                                android:layout_height="220dp"
                                android:scaleType="fitCenter"
                                android:contentDescription="QR Code" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- Info Note -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="📋  Show this token while collecting your order"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="13sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Back to Menu Button — ID preserved: backBtn -->
            <Button
                android:id="@+id/backBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_primary"
                android:text="Back to Menu"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
