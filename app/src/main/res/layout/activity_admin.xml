<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Canteen Admin"
            android:textColor="#2B2D42"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage canteen details, menu and orders"
            android:textColor="#7A7A7A"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Canteen Details Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:id="@+id/canteenFormLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Canteen Information"
                    android:textColor="#2B2D42"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/canteenNameEt"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="14dp"
                    android:background="@android:drawable/editbox_background"
                    android:hint="Canteen Name"
                    android:paddingHorizontal="16dp"
                    android:textColor="#2B2D42"
                    android:textColorHint="#9E9E9E" />

                <EditText
                    android:id="@+id/collegeNameEt"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="14dp"
                    android:background="@android:drawable/editbox_background"
                    android:hint="College Name"
                    android:paddingHorizontal="16dp"
                    android:textColor="#2B2D42"
                    android:textColorHint="#9E9E9E" />

                <EditText
                    android:id="@+id/locationEt"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@android:drawable/editbox_background"
                    android:hint="Location"
                    android:paddingHorizontal="16dp"
                    android:textColor="#2B2D42"
                    android:textColorHint="#9E9E9E" />

                <Button
                    android:id="@+id/saveBtn"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#228B22"
                    android:text="Save Canteen"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Menu Management Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:id="@+id/menuLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menu Management"
                    android:textColor="#2B2D42"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/itemNameEt"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="14dp"
                    android:background="@android:drawable/editbox_background"
                    android:hint="Item Name"
                    android:paddingHorizontal="16dp"
                    android:textColor="#2B2D42"
                    android:textColorHint="#9E9E9E" />

                <EditText
                    android:id="@+id/itemPriceEt"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="14dp"
                    android:background="@android:drawable/editbox_background"
                    android:hint="Price"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:textColor="#2B2D42"
                    android:textColorHint="#9E9E9E" />

                <Spinner
                    android:id="@+id/itemTypeSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:background="#F4F4F4"
                    android:paddingHorizontal="12dp" />

                <Button
                    android:id="@+id/addItemBtn"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:backgroundTint="#B7E4C7"
                    android:text="Add Menu Item"
                    android:textAllCaps="false"
                    android:textColor="#2B2D42"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ListView
                    android:id="@+id/menuListView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:divider="#ECECEC"
                    android:dividerHeight="10dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Order Verification Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verify Orders"
                    android:textColor="#2B2D42"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="18dp" />

                <Button
                    android:id="@+id/scanBtn"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:backgroundTint="#A9D6E5"
                    android:text="Scan QR Code"
                    android:textAllCaps="false"
                    android:textColor="#2B2D42"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/orderIdEt"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@android:drawable/editbox_background"
                    android:hint="Enter Order ID"
                    android:paddingHorizontal="16dp"
                    android:textColor="#2B2D42"
                    android:textColorHint="#9E9E9E" />

                <Button
                    android:id="@+id/verifyBtn"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#FFD6BA"
                    android:text="Mark as Completed"
                    android:textAllCaps="false"
                    android:textColor="#2B2D42"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
