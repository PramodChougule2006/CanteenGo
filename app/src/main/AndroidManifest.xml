<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CanteenGo">

        <activity
            android:name=".ui.TokenActivity"
            android:exported="false"
            android:label="@string/title_activity_token"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.PaymentActivity"
            android:exported="true"
            android:label="@string/title_activity_payment"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.OrderActivity"
            android:exported="false"
            android:label="@string/title_activity_order"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.CartActivity"
            android:exported="false"
            android:label="@string/title_activity_cart"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.MenuActivity"
            android:exported="false"
            android:label="@string/title_activity_menu"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.UserActivity"
            android:exported="false"
            android:label="@string/title_activity_user"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.AdminActivity"
            android:exported="false"
            android:label="@string/title_activity_admin"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.SignupActivity"
            android:exported="false"
            android:label="@string/title_activity_signup"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.OrderHistoryActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CanteenGo" />

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CanteenGo">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>